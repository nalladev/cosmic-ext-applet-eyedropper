{
  "id": "io.github.nalladev.CosmicExtAppletEyedropper",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable", "org.freedesktop.Sdk.Extension.llvm20"],
  "command": "cosmic-ext-applet-eyedropper",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--talk-name=com.system76.CosmicSettingsDaemon",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--filesystem=xdg-config/cosmic:rw",
    "--filesystem=xdg-run/pipewire-0"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm20/bin",
    "env": {
      "CARGO_HOME": "/run/build/cosmic-ext-applet-eyedropper/cargo",
      "LIBCLANG_PATH": "/usr/lib/sdk/llvm20/lib"
    }
  },
  "modules": [
    {
      "name": "cosmic-ext-applet-eyedropper",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 cargo/config .cargo/config.toml",
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo --offline build --release --verbose",
        "install -Dm0755 ./target/release/cosmic-ext-applet-eyedropper /app/bin/cosmic-ext-applet-eyedropper",
        "install -Dm0644 ./resources/app.desktop /app/share/applications/io.github.nalladev.CosmicExtAppletEyedropper.desktop",
        "install -Dm0644 ./resources/app.metainfo.xml /app/share/metainfo/io.github.nalladev.CosmicExtAppletEyedropper.metainfo.xml",
        "install -Dm0644 ./resources/icon.svg /app/share/icons/hicolor/scalable/apps/io.github.nalladev.CosmicExtAppletEyedropper.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        },
        "cargo-sources.json",
        {
          "type": "git",
          "url": "https://github.com/wash2/accesskit",
          "tag": "cosmic-0.14",
          "commit": "f0599eed5f18111228266fe3f28991cc48b5964f",
          "dest": "flatpak-cargo/git/accesskit"
        },
        {
          "type": "git",
          "url": "https://github.com/jackpot51/rust-atomicwrites",
          "commit": "043ab4859d53ffd3d55334685303d8df39c9f768",
          "dest": "flatpak-cargo/git/rust-atomicwrites"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/window_clipboard.git",
          "tag": "sctk-0.20",
          "commit": "f68595ee0e62fbd6589f4709b5aaa5c3c7ea5f6c",
          "dest": "flatpak-cargo/git/window_clipboard"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/cosmic-protocols",
          "commit": "32283d76a8d0342da74c4cc022a533c52dcf378f",
          "dest": "flatpak-cargo/git/cosmic-protocols"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/libcosmic.git",
          "commit": "c44dbe793b64caa8604dc38816c9b791e7ecb8ac",
          "dest": "flatpak-cargo/git/libcosmic"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/freedesktop-icons",
          "commit": "ab4c57b8e416c6af9297cb04d101889896fd9a92",
          "dest": "flatpak-cargo/git/freedesktop-icons"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/cosmic-panel",
          "commit": "029400b2b447d9d31f1a772d7f6f0d5eed2ea21e",
          "dest": "flatpak-cargo/git/cosmic-panel"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/dbus-settings-bindings",
          "commit": "eed01dd3609e90e3c8cd043656734c500956c793",
          "dest": "flatpak-cargo/git/dbus-settings-bindings"
        },
        {
          "type": "git",
          "url": "https://github.com/iced-rs/cryoglyph.git",
          "commit": "e429a025df36ab8145708acb309080ae3deec17a",
          "dest": "flatpak-cargo/git/cryoglyph"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/smithay-clipboard",
          "tag": "sctk-0.20",
          "commit": "859b02c88f45c554049a67c6ddeec1692ce0e20b",
          "dest": "flatpak-cargo/git/smithay-clipboard"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/softbuffer",
          "tag": "cosmic-4.0",
          "commit": "c2b2c19ddb38ff17495643699f97cb1f2064a1be",
          "dest": "flatpak-cargo/git/softbuffer"
        },
        {
          "type": "git",
          "url": "https://github.com/pop-os/winit.git",
          "tag": "cosmic-0.14",
          "commit": "f737f1f5900b3399b56951305b0f155afc9c9ee5",
          "dest": "flatpak-cargo/git/winit"
        }
      ]
    }
  ]
}